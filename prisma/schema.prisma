// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

// ─── PostShip: App Settings ──────────────────────────────────────────────────

model AppSettings {
  id        String   @id @default(cuid())
  shop      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Subscription ──────────────────────────────────────────────────────────
  // "free" | "starter" | "pro"
  // Set by Shopify Billing API callback (Phase 3).
  plan      String @default("free")

  // ── Order management ──────────────────────────────────────────────────────
  cancellationWindowHours Int @default(2)

  // ── Email ─────────────────────────────────────────────────────────────────
  // Resend API key stored per-merchant (they supply their own key on free plan,
  // or we use a shared platform key on Starter/Pro — Phase 3 decision).
  resendApiKey        String  @default("")
  fromEmail           String  @default("")        // e.g. "orders@yourstore.com"
  senderName          String  @default("")        // e.g. "Your Store"

  enableTrackingEmails Boolean @default(true)
  enableReviewEmails   Boolean @default(false)    // Starter+

  // ── Post-delivery review + coupon ─────────────────────────────────────────
  reviewRequestDelayDays Int     @default(7)      // days after delivered
  enableCoupon           Boolean @default(false)  // include coupon in review email
  couponCode             String  @default("")     // e.g. "THANKYOU10"
  couponDiscountPercent  Int     @default(10)     // 1–100
  couponExpiryDays       Int     @default(30)     // days until coupon expires

  // ── Branding ──────────────────────────────────────────────────────────────
  brandColor String @default("#5c6ac4")

  // ── WhatsApp ──────────────────────────────────────────────────────────────
  whatsappNumber String @default("")   // include country code e.g. +1234567890

  onboardingStep1  Boolean @default(false)
  onboardingStep2  Boolean @default(false)
  onboardingStep3  Boolean @default(false)
  onboardingDone   Boolean @default(false)

}

// ─── PostShip: Return Requests ───────────────────────────────────────────────

model ReturnRequest {
  id            String    @id @default(cuid())
  shop          String
  orderId       String
  orderName     String
  customerEmail String
  items         String    // JSON: Array<{ id, title }>
  reason        String
  notes         String    @default("")
  type          String    @default("return")   // "return" | "exchange"
  status        String    @default("pending")  // pending | approved | rejected | processing | completed
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shop])
  @@index([orderId])
}

// ─── PostShip: Cancellation Requests ────────────────────────────────────────

model CancellationRequest {
  id            String    @id @default(cuid())
  shop          String
  orderId       String
  orderName     String
  customerEmail String
  reason        String
  notes         String    @default("")
  status        String    @default("pending")  // pending | approved | rejected | auto-rejected
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shop])
  @@index([orderId])
}

// ─── PostShip: Support Tickets ───────────────────────────────────────────────

model SupportTicket {
  id            String    @id @default(cuid())
  shop          String
  orderId       String
  orderName     String
  customerEmail String
  issueType     String    // "damaged" | "missing" | "wrong_item" | "not_delivered" | "other"
  description   String
  status        String    @default("open")  // open | in_progress | resolved
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shop])
  @@index([status])
}

// ─── PostShip: Delivery Feedback ─────────────────────────────────────────────

model DeliveryFeedback {
  id            String   @id @default(cuid())
  shop          String
  orderId       String
  orderName     String
  customerEmail String
  rating        Int      // 1–5
  comment       String   @default("")
  createdAt     DateTime @default(now())

  @@index([shop])
  @@index([orderId])
}

// ─── PostShip: Email Log (dedup + audit) ─────────────────────────────────────
// Prevents duplicate tracking emails if the webhook fires more than once.

model EmailLog {
  id        String   @id @default(cuid())
  shop      String
  orderId   String
  type      String   // "tracking_shipped" | "tracking_delivered" | "review_request"
  sentAt    DateTime @default(now())

  @@unique([shop, orderId, type])   // one email per order per type per shop
  @@index([shop])
}
